<UserControl x:Class="CapLed.Desktop.Views.Users.UserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CapLed.Desktop.Views.Users"
             xmlns:conv="clr-namespace:CapLed.Desktop.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="#F1F5F9">

    <Grid Margin="30">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="500"/>
            <ColumnDefinition Width="400"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT COLUMN: USER LIST -->
        <Grid Grid.Column="0" Margin="0,0,30,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,25">
                <StackPanel>
                    <TextBlock Text="Gestion des Utilisateurs" FontSize="28" FontWeight="Bold" Foreground="#1E293B"/>
                    <TextBlock Text="Administrez les accès et rôles des collaborateurs" Foreground="#64748B" Margin="0,4,0,0"/>
                </StackPanel>
                <Button DockPanel.Dock="Right" Content="Actualiser" Command="{Binding RefreshCommand}" 
                        Style="{StaticResource ActionButton}" Background="#334155" HorizontalAlignment="Right" Width="120" Height="36"/>
            </DockPanel>

            <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="1" Effect="{DynamicResource SubtleShadow}">
                <DataGrid ItemsSource="{Binding Users}"
                          SelectedItem="{Binding SelectedUser}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F1F5F9"
                          Background="White"
                          BorderThickness="0"
                          RowHeight="50">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="NOM COMPLET" Binding="{Binding FullName}" Width="*" FontWeight="SemiBold"/>
                        <DataGridTextColumn Header="EMAIL" Binding="{Binding Email}" Width="*"/>
                        <DataGridTextColumn Header="RÔLE" Binding="{Binding DisplayRole}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- RIGHT COLUMN: FORM -->
        <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="25" Effect="{DynamicResource SubtleShadow}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,25">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Nouvel Utilisateur"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                        <Setter Property="Text" Value="Modifier l'Utilisateur"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Feedback -->
                    <Border Style="{StaticResource ErrorMessageStyle}"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
                        <TextBlock Text="{Binding ErrorMessage}"/>
                    </Border>
                    <Border Style="{StaticResource SuccessMessageStyle}"
                            Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibility}}">
                        <TextBlock Text="{Binding SuccessMessage}"/>
                    </Border>

                    <!-- Fields -->
                    <TextBlock Text="Nom Complet" Foreground="#64748B" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,0,20"/>

                    <TextBlock Text="Email" Foreground="#64748B" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,0,20"/>

                    <TextBlock Text="Rôle" Foreground="#64748B" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding Roles}" SelectedItem="{Binding SelectedRole}" Margin="0,0,0,20" Height="36" VerticalContentAlignment="Center">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>


                    <StackPanel Visibility="{Binding IsEditMode, Converter={StaticResource InvBoolToVis}}">
                        <TextBlock Text="Mot de passe" Foreground="#64748B" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <PasswordBox x:Name="PassBox" Margin="0,0,0,15" Height="36" Padding="8,4" 
                                     local:PasswordBoxHelper.Attach="True" 
                                     local:PasswordBoxHelper.Password="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Confirmer le mot de passe" Foreground="#64748B" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <PasswordBox x:Name="ConfirmPassBox" Margin="0,0,0,25" Height="36" Padding="8,4"
                                     local:PasswordBoxHelper.Attach="True"
                                     local:PasswordBoxHelper.Password="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Actions -->
                    <Button Content="Enregistrer" Command="{Binding SaveUserCommand}" Style="{StaticResource ActionButton}" Margin="0,0,0,12" Height="42"
                            IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBool}}"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Nouveau" Command="{Binding AddUserCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,5,0"/>
                        <Button Grid.Column="1" Content="Vider" Command="{Binding ClearFormCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="5,0,0,0"/>
                    </Grid>

                    <Button Content="Modifier Sélection" Command="{Binding EditUserCommand}" Style="{StaticResource ActionButton}" Background="#64748B" Margin="0,15,0,0" Height="36"
                            IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBool}}"/>
                    <Button Content="Supprimer" Command="{Binding DeleteUserCommand}" Style="{StaticResource ActionButton}" Background="#EF4444" Margin="0,10,0,0" Height="36"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
