<UserControl x:Class="CapLed.Desktop.Views.Stock.StockDetailPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">

    <Border Background="White" CornerRadius="10" BorderBrush="#E2E8F0" BorderThickness="1"
            Padding="0" Margin="0,15,0,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Header -->
                <RowDefinition Height="Auto"/>  <!-- Stats bar -->
                <RowDefinition Height="*"/>     <!-- Table -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#F8FAFC" CornerRadius="10,10,0,0" Padding="16,12">
                <DockPanel>
                    <StackPanel>
                        <TextBlock Text="{Binding ArticleName}" FontSize="15" FontWeight="Bold" Foreground="#1E293B"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Détail stock · " Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding TypeGestion}" Foreground="#64748B" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text=" · Total : " Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding TotalQuantite}" Foreground="#1E293B" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Text=" pièces" Foreground="#64748B" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                    <Button DockPanel.Dock="Right" Content="✕" Width="28" Height="28"
                            HorizontalAlignment="Right" Command="{Binding CloseCommand}"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#94A3B8" FontSize="14" Cursor="Hand"/>
                </DockPanel>
            </Border>

            <!-- Loading -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                <ProgressBar IsIndeterminate="True" Width="80" Height="4"/>
                <TextBlock Text="Chargement..." Margin="10,0,0,0" Foreground="#64748B"/>
            </StackPanel>

            <!-- ── MODE LOT ── -->
            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding Lots}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#F1F5F9" Background="White"
                      BorderThickness="0" RowHeight="38" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsLotMode, Converter={StaticResource BoolToVis}}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="N° LOT" Binding="{Binding NumeroLot}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#1D4ED8"/>
                                <Setter Property="Padding" Value="10,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="DÉPÔT" Binding="{Binding DepotNom}" Width="120"/>
                    <DataGridTextColumn Header="QUANTITÉ" Binding="{Binding Quantite}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="DATE ENTRÉE" Binding="{Binding DateEntree, StringFormat='dd/MM/yyyy'}" Width="110"/>
                    <DataGridTextColumn Header="FOURNISSEUR" Binding="{Binding Fournisseur}" Width="*"/>
                    <DataGridTextColumn Header="GARANTIE" Binding="{Binding Garantie}" Width="90"/>
                    <DataGridTextColumn Header="CERTIFICAT" Binding="{Binding Certificat}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- ── MODE SERIALISE ── -->
            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding Series}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#F1F5F9" Background="White"
                      BorderThickness="0" RowHeight="38" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsSerieMode, Converter={StaticResource BoolToVis}}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="N° SÉRIE" Binding="{Binding NumeroSerie}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#15803D"/>
                                <Setter Property="Padding" Value="10,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="DÉPÔT" Binding="{Binding DepotNom}" Width="120"/>
                    <DataGridTemplateColumn Header="STATUT" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Padding="8,2" HorizontalAlignment="Left" Margin="5,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#DCFCE7"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Statut}" Value="SORTI">
                                                    <Setter Property="Background" Value="#FEE2E2"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Statut}" Value="RESERVE">
                                                    <Setter Property="Background" Value="#FEF9C3"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Statut}" Value="DEFECTUEUX">
                                                    <Setter Property="Background" Value="#F1F5F9"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="11" FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding Statut}"/>
                                                <Setter Property="Foreground" Value="#15803D"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Statut}" Value="SORTI">
                                                        <Setter Property="Foreground" Value="#B91C1C"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Statut}" Value="RESERVE">
                                                        <Setter Property="Foreground" Value="#854D0E"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Statut}" Value="DEFECTUEUX">
                                                        <Setter Property="Foreground" Value="#64748B"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="DATE ENTRÉE" Binding="{Binding DateEntree, StringFormat='dd/MM/yyyy'}" Width="110"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- ── MODE QUANTITE (message) ── -->
            <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsQuantiteMode, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="📦" FontSize="32" HorizontalAlignment="Center"/>
                <TextBlock Text="Gestion par quantité globale" Foreground="#64748B" FontSize="13"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
                <TextBlock Foreground="#94A3B8" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0">
                    <Run Text="Quantité disponible : "/>
                    <Run Text="{Binding TotalQuantite}" FontWeight="Bold" Foreground="#1E293B"/>
                    <Run Text=" pièces"/>
                </TextBlock>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
