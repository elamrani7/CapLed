<UserControl x:Class="CapLed.Desktop.Views.Equipment.EquipmentListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CapLed.Desktop.Views.Equipment"
             xmlns:stockViews="clr-namespace:CapLed.Desktop.Views.Stock"
             xmlns:viewmodels="clr-namespace:CapLed.Desktop.ViewModels"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=viewmodels:EquipmentListViewModel}"
             Background="#F5F7F9">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Status/Header -->
            <RowDefinition Height="Auto"/>  <!-- Filters -->
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="*"/>     <!-- Grid -->
            <RowDefinition Height="Auto"/>  <!-- Detail Panel -->
            <RowDefinition Height="Auto"/>  <!-- Pagination -->
        </Grid.RowDefinitions>

        <!-- 1. Header & Messages -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Inventaire des Équipements" FontSize="28" FontWeight="Bold" Foreground="#1A2436"/>
            
            <!-- Error Banner -->
            <Border Style="{StaticResource ErrorMessageStyle}"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
                <TextBlock Text="{Binding ErrorMessage}"/>
            </Border>

            <!-- Success Banner -->
            <Border Style="{StaticResource SuccessMessageStyle}"
                    Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibility}}">
                <TextBlock Text="{Binding SuccessMessage}"/>
            </Border>
        </StackPanel>

        <!-- 2. Filters -->
        <Border Grid.Row="1" Background="White" CornerRadius="6" Padding="15" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <!-- Search -->
                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="Rechercher" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <TextBox Width="200" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Height="34" VerticalContentAlignment="Center" Padding="8,0">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                </StackPanel>

                <!-- Famille -->
                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="Famille" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <ComboBox Width="180" Height="34" 
                              ItemsSource="{Binding Familles}" 
                              SelectedItem="{Binding SelectedFamille}"
                              DisplayMemberPath="Libelle">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Padding" Value="5"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>
                </StackPanel>

                <!-- Category -->
                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="Catégorie" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <ComboBox Width="180" Height="34" 
                              ItemsSource="{Binding Categories}" 
                              SelectedItem="{Binding SelectedCategory}"
                              DisplayMemberPath="Label">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Padding" Value="5"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>
                </StackPanel>

                <!-- Condition -->
                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="État" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <ComboBox Width="120" Height="34"
                              ItemsSource="{Binding ConditionOptions}"
                              SelectedItem="{Binding SelectedCondition}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource EnumToString}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!-- Action Buttons -->
                <Button Content="Appliquer" Command="{Binding SearchCommand}" 
                        Style="{StaticResource ActionButton}" Margin="10,20,5,0" Width="100"/>
                <Button Content="Réinitialiser" Command="{Binding ClearFiltersCommand}" 
                        Background="Transparent" BorderBrush="#CBD5E1" Foreground="#475569"
                        Style="{StaticResource ActionButton}" Margin="5,20,0,0" Width="120"/>
            </StackPanel>
        </Border>

        <!-- 3. Toolbar -->
        <DockPanel Grid.Row="2" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <Button Content="+ Ajouter" Command="{Binding AddEquipmentCommand}" 
                        Style="{StaticResource ActionButton}" Background="#1A2436" Margin="0,0,8,0" Width="120"/>
                <Button Content="Modifier" Command="{Binding EditEquipmentCommand}" 
                        Style="{StaticResource ActionButton}" Background="White" Foreground="#1A2436" BorderBrush="#E2E8F0"
                        Margin="0,0,8,0" Width="100"/>
                <Button Content="Supprimer" Command="{Binding DeleteEquipmentCommand}" 
                        Style="{StaticResource ActionButton}" Background="#FEE2E2" Foreground="#EF4444" BorderBrush="#FECACA"
                        Width="100"/>
            </StackPanel>

            <!-- Loading Spinner Placeholder -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                <ProgressBar IsIndeterminate="True" Width="100" Height="4" VerticalAlignment="Center"/>
                <TextBlock Text="Chargement..." Margin="10,0,0,0" Foreground="#64748B" VerticalAlignment="Center"/>
            </StackPanel>
        </DockPanel>

        <!-- 4. DataGrid -->
        <Border Grid.Row="3" Background="White" CornerRadius="6" BorderBrush="#E2E8F0" BorderThickness="1">
            <DataGrid ItemsSource="{Binding EquipmentItems}" 
                      SelectedItem="{Binding SelectedEquipment}"
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      HeadersVisibility="Column"
                      BorderThickness="0"
                      Background="White"
                      RowHeight="40"
                      HorizontalGridLinesBrush="#F1F5F9"
                      VerticalGridLinesBrush="Transparent">
                <DataGrid.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick"
                                  Command="{Binding ViewStockDetailCommand}"
                                  CommandParameter="{Binding SelectedEquipment}"/>
                </DataGrid.InputBindings>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="NOM" Binding="{Binding Name}" Width="2*" />
                    <DataGridTextColumn Header="CATÉGORIE" Binding="{Binding CategoryName}" Width="*" />
                    <DataGridTextColumn Header="RÉFÉRENCE" Binding="{Binding Reference}" Width="1.5*" />

                    <!-- Colonne Type de Gestion Stock -->
                    <DataGridTemplateColumn Header="GESTION" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" Margin="5,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#F1F5F9"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TypeGestionStock}" Value="LOT">
                                                    <Setter Property="Background" Value="#EFF6FF"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding TypeGestionStock}" Value="SERIALISE">
                                                    <Setter Property="Background" Value="#F0FDF4"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="10" FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="QUANTITÉ"/>
                                                <Setter Property="Foreground" Value="#64748B"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TypeGestionStock}" Value="LOT">
                                                        <Setter Property="Text" Value="LOT"/>
                                                        <Setter Property="Foreground" Value="#1D4ED8"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding TypeGestionStock}" Value="SERIALISE">
                                                        <Setter Property="Text" Value="SÉRIES"/>
                                                        <Setter Property="Foreground" Value="#15803D"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="ÉTAT" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Padding="8,2" HorizontalAlignment="Left"
                                        Background="{Binding Condition, Converter={StaticResource ConditionToBrush}}">
                                    <TextBlock Text="{Binding Condition, Converter={StaticResource EnumToString}}" 
                                               FontSize="11" FontWeight="Bold" Foreground="White" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="QTÉ" Binding="{Binding Quantity}" Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="SEUIL" Binding="{Binding MinThreshold}" Width="70">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="#94A3B8"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="ALERTE" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <!-- File: EquipmentListView.xaml -->
                                <ContentControl Content="{Binding}" 
                                                ContentTemplate="{StaticResource StockAlertBadgeTemplate}" 
                                                HorizontalAlignment="Left" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- 4. Stock Detail Panel (visible on row double-click) -->
        <stockViews:StockDetailPanel Grid.Row="4"
                                     DataContext="{Binding StockDetail}"
                                     MaxHeight="260"
                                     Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}"/>

        <!-- 5. Pagination -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <TextBlock VerticalAlignment="Center" Margin="0,0,15,0" Foreground="#475569">
                <Run Text="{Binding TotalCount}"/>
                <Run Text="résultats — Page"/>
                <Run Text="{Binding Page}" FontWeight="Bold"/>
                <Run Text="sur"/>
                <Run Text="{Binding TotalPages}" FontWeight="Bold"/>
            </TextBlock>
            <Button Content="Précédent" Command="{Binding PreviousPageCommand}" 
                    Style="{StaticResource ActionButton}" Background="White" Foreground="#475569" BorderBrush="#CBD5E1" 
                    Width="100" Margin="0,0,5,0"/>
            <Button Content="Suivant" Command="{Binding NextPageCommand}" 
                    Style="{StaticResource ActionButton}" Background="White" Foreground="#475569" BorderBrush="#CBD5E1" 
                    Width="100"/>
        </StackPanel>
    </Grid>
</UserControl>
