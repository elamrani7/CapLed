<Window x:Class="CapLed.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CapLed.Desktop.ViewModels"
        xmlns:views="clr-namespace:CapLed.Desktop.Views"
        xmlns:conv="clr-namespace:CapLed.Desktop.Converters"
        xmlns:dashboard="clr-namespace:CapLed.Desktop.Views.Dashboard"
        xmlns:equipment="clr-namespace:CapLed.Desktop.Views.Equipment"
        xmlns:categories="clr-namespace:CapLed.Desktop.Views.Categories"
        xmlns:stock="clr-namespace:CapLed.Desktop.Views.Stock"
        xmlns:alerts="clr-namespace:CapLed.Desktop.Views.Alerts"
        xmlns:users="clr-namespace:CapLed.Desktop.Views.Users"
        Title="CapLed — Gestion de Stock"
        MinWidth="1100" MinHeight="680"
        Width="1280" Height="780"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">

    <Window.Resources>
        <conv:BoolToVisibilityConverter   x:Key="BoolToVisibility"/>
        <conv:EnumToStringConverter       x:Key="EnumToString"/>
        <conv:StringEqualityConverter     x:Key="StringEquality"/>

        <!-- ── DataTemplate wiring: ViewModel → View ────────────────────── -->
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <dashboard:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EquipmentListViewModel}">
            <equipment:EquipmentListView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EquipmentDetailViewModel}">
            <equipment:EquipmentDetailView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CategoryViewModel}">
            <categories:CategoryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StockMovementViewModel}">
            <stock:StockMovementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AlertsViewModel}">
            <alerts:AlertsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UserViewModel}">
            <users:UserView/>
        </DataTemplate>

        <!-- ── Nav Button Style ─────────────────────────────────────────── -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background"         Value="Transparent"/>
            <Setter Property="Foreground"         Value="#B0BEC5"/>
            <Setter Property="BorderThickness"    Value="0"/>
            <Setter Property="Height"             Value="48"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"            Value="20,0"/>
            <Setter Property="FontSize"           Value="14"/>
            <Setter Property="FontFamily"         Value="Segoe UI"/>
            <Setter Property="Cursor"             Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="0,0,0,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1AFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active nav button override -->
        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="Background"  Value="#1AFFFFFF"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>   <!-- Sidebar -->
            <ColumnDefinition Width="*"/>     <!-- Content -->
        </Grid.ColumnDefinitions>

        <!-- ════ SIDEBAR ═══════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="#1A2436">
            <DockPanel>

                <!-- Logo / Brand -->
                <Border DockPanel.Dock="Top"
                        Padding="20,28,20,20"
                        BorderBrush="#2D3C52"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="CapLed"
                                   Foreground="White"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   FontFamily="Segoe UI"/>
                        <TextBlock Text="Gestion de stock"
                                   Foreground="#78909C"
                                   FontSize="11"
                                   FontFamily="Segoe UI"/>
                    </StackPanel>
                </Border>

                <!-- Nav Section Label -->
                <TextBlock DockPanel.Dock="Top"
                           Text="MENU PRINCIPAL"
                           Foreground="#455A64"
                           FontSize="10"
                           FontWeight="Bold"
                           FontFamily="Segoe UI"
                           Padding="20,16,0,8"/>

                <!-- Navigation Buttons -->
                <StackPanel DockPanel.Dock="Top">

                    <!-- Dashboard -->
                    <Button Command="{Binding ShowDashboardCommand}">
                        <!-- We use DataTrigger on ActiveSection for active state highlighting -->
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSection}" Value="Dashboard">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Background" Value="#1AFFFFFF"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Tableau de bord"  VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Equipment -->
                    <Button Command="{Binding ShowEquipmentCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSection}" Value="Equipment">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Background" Value="#1AFFFFFF"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔧" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Équipements"     VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Categories -->
                    <Button Command="{Binding ShowCategoriesCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSection}" Value="Categories">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Background" Value="#1AFFFFFF"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗂️" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Catégories"      VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Stock -->
                    <Button Command="{Binding ShowStockCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSection}" Value="Stock">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Background" Value="#1AFFFFFF"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📦" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Mouvements"      VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Alerts -->
                    <Button Command="{Binding ShowAlertsCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSection}" Value="Alerts">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Background" Value="#1AFFFFFF"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠️" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Alertes stock"   VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Users -->
                    <Button Command="{Binding ShowUsersCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSection}" Value="Users">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Background" Value="#1AFFFFFF"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Utilisateurs"    VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

                <!-- Bottom: version / user info -->
                <Border DockPanel.Dock="Bottom"
                        Padding="20,12"
                        BorderBrush="#2D3C52"
                        BorderThickness="0,1,0,0">
                    <StackPanel>
                        <TextBlock Text="CapLed v1.0"
                                   Foreground="#455A64"
                                   FontSize="11"
                                   FontFamily="Segoe UI"/>
                    </StackPanel>
                </Border>

            </DockPanel>
        </Border>

        <!-- ════ MAIN CONTENT AREA ═══════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Top bar -->
                <RowDefinition Height="*"/>      <!-- Page content -->
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Border Grid.Row="0"
                    Background="White"
                    Padding="24,0"
                    Height="56"
                    BorderBrush="#E0E3E7"
                    BorderThickness="0,0,0,1">
                <DockPanel>
                    <!-- Page title from CurrentViewModel -->
                    <TextBlock DockPanel.Dock="Left"
                               Text="{Binding ActiveSection}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#1A2436"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>

                    <!-- Loading indicator -->
                    <TextBlock DockPanel.Dock="Right"
                               Text="Chargement…"
                               Foreground="#78909C"
                               FontSize="12"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center"
                               Visibility="{Binding CurrentViewModel.IsLoading, Converter={StaticResource BoolToVisibility}}"/>
                </DockPanel>
            </Border>

            <!-- Page Content: auto-resolved via DataTemplates above -->
            <ContentControl Grid.Row="1"
                            Content="{Binding CurrentViewModel}"
                            Margin="0"/>
        </Grid>

    </Grid>
</Window>
